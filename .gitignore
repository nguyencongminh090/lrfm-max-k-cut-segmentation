# Data (do not commit the dataset)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Results artifacts
results/figures/*
results/tables/*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Gurobi
gurobi.log
*.lp
*.mps

# LaTeX build artifacts
*.aux
*.log
*.out
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.lof
*.lot
# Keep .bbl and .blg if required, but usually they are ignored too. Let's ignore them.
*.bbl
*.blg

